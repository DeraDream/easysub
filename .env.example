# ===== Docker Compose 根配置 =====
# 复制为 .env 后修改：  cp .env.example .env
#
# 默认 docker-compose 会启动 MySQL 8，并通过下面的 EASYSUB_DB_* 自动初始化。
# 若这些变量留空或未配置，首次访问网页时仍会进入「数据库安装向导」。

# ---- 应用 ----
# JWT 密钥（务必改成随机长字符串，可用： openssl rand -hex 32）
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
TZ=Asia/Shanghai

# ---- 数据库自动初始化（docker-compose 默认可直接使用）----
EASYSUB_DB_HOST=db
EASYSUB_DB_PORT=3306
EASYSUB_DB_USER=easysub
EASYSUB_DB_PASSWORD=change-me-db-password
EASYSUB_DB_NAME=easysub
MYSQL_ROOT_PASSWORD=change-me-root-password

# Telegram（@BotFather 获取）
TELEGRAM_BOT_TOKEN=

# 汇率 API（默认 open.er-api.com，免费免 key）
EXCHANGE_API_BASE=USD
EXCHANGE_API_URL=https://open.er-api.com/v6/latest/
EXCHANGE_API_KEY=

# 每日提醒扫描时间 HH:MM
REMINDER_SCAN_TIME=09:00

# 首个管理员（数据库初始化时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
