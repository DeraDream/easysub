# ===== Docker Compose 根配置 =====
# 复制为 .env 后修改：  cp .env.example .env
#
# 注意：本项目【不自带数据库】，连接你已有的 MySQL。
#       数据库连接信息不在这里配置，而是首次访问网页时在「数据库安装向导」里填写并测试。

# ---- 应用 ----
# JWT 密钥（务必改成随机长字符串，可用： openssl rand -hex 32）
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
TZ=Asia/Shanghai

# Telegram（@BotFather 获取）
TELEGRAM_BOT_TOKEN=

# 汇率 API（默认 open.er-api.com，免费免 key）
EXCHANGE_API_BASE=USD
EXCHANGE_API_URL=https://open.er-api.com/v6/latest/
EXCHANGE_API_KEY=

# 每日提醒扫描时间 HH:MM
REMINDER_SCAN_TIME=09:00

# 首个管理员（数据库初始化时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
