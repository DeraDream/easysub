# ===== 基础 =====
# 数据库连接不在此配置：首次访问网页会进入「数据库安装向导」，
# 在网页上填写 MySQL 主机/端口/用户/密码/库名并测试连接后保存。

# JWT 密钥（生产务必改成随机长字符串）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# 时区（定时提醒按此时区运行）
TZ=Asia/Shanghai

# ===== Telegram =====
# 通过 @BotFather 获取
TELEGRAM_BOT_TOKEN=

# ===== 汇率 API =====
# 默认使用 open.er-api.com（免费免 key）。如用需要 key 的服务在此填入
EXCHANGE_API_BASE=USD
EXCHANGE_API_URL=https://open.er-api.com/v6/latest/
EXCHANGE_API_KEY=

# 每日提醒扫描时间（24h，HH:MM）
REMINDER_SCAN_TIME=09:00

# 首个管理员账户（首次启动自动创建；留空则需手动注册）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
